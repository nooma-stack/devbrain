# DevBrain environment variables.
#
# Copy this file to .env and edit values as needed. The .env file is gitignored.
# Precedence: env > config/devbrain.yaml > built-in defaults.
#
# All vars below are OPTIONAL — DevBrain will fall back to config.yaml or
# defaults if a var is unset. Set the ones you need to override.

# ─── Paths ────────────────────────────────────────────────────────────────────

# Where DevBrain is installed. Used by mcp-server/run.sh, the launchd plist
# template, and Python config loaders. Defaults to the repo root inferred
# from each entrypoint's location.
# DEVBRAIN_HOME=/path/to/devbrain

# Override the config file location. Defaults to $DEVBRAIN_HOME/config/devbrain.yaml.
# DEVBRAIN_CONFIG=/path/to/custom/devbrain.yaml

# ─── Database ─────────────────────────────────────────────────────────────────

# Postgres password. The installer generates a random value on first run
# and writes it here. Required — docker-compose will refuse to start the
# database container without it. To rotate, set a new value here and run
# the rotation steps in docs/rotate-db-password.md.
# DEVBRAIN_DB_PASSWORD=

# Override the published host port (default 5433). The container is bound
# to 127.0.0.1 so it's only reachable from this machine.
# DEVBRAIN_DB_HOST_PORT=5433

# Full Postgres connection URL. Overrides yaml.database.* if set.
# DEVBRAIN_DATABASE_URL=postgresql://devbrain:REPLACE_WITH_DEVBRAIN_DB_PASSWORD@localhost:5433/devbrain

# ─── Ollama ───────────────────────────────────────────────────────────────────

# Ollama server URL. Applies to both embedding and summarization.
# DEVBRAIN_OLLAMA_URL=http://localhost:11434

# Embedding model. Must be pulled in Ollama (`ollama pull <model>`).
# DEVBRAIN_EMBEDDING_MODEL=snowflake-arctic-embed2

# Summarization / NL-query model.
# DEVBRAIN_SUMMARY_MODEL=qwen2.5:7b

# ─── Hooks ────────────────────────────────────────────────────────────────────

# Project slug used by hooks/session-start.sh when generating context.
# Set this in your shell rc to scope hook output per project.
# DEVBRAIN_PROJECT=myproject

# ─── Notifications (channel-specific secrets) ─────────────────────────────────

# Telegram bot token (overrides yaml.notifications.channels.telegram_bot.bot_token).
# TELEGRAM_BOT_TOKEN=
