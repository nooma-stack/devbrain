# DevBrain Configuration (Template)
# ==================================
# Copy this file to config/devbrain.yaml and fill in your values.
# The real config/devbrain.yaml is gitignored so secrets stay local.

database:
  host: localhost
  port: 5433
  user: devbrain
  # Replaced with a random value by scripts/install.sh when this template
  # is copied to config/devbrain.yaml. Do not commit a real password.
  password: REPLACE_DURING_INSTALL
  database: devbrain

embedding:
  provider: ollama
  url: http://localhost:11434
  model: snowflake-arctic-embed2
  dims: 1024

summarization:
  provider: ollama
  url: http://localhost:11434
  model: qwen2.5:7b

chunking:
  max_tokens: 400
  overlap_tokens: 80

ingest:
  # Path → project_slug mappings. Used by claude_code, codex, and any
  # other path-aware adapter to attribute sessions to a project.
  # Each adapter applies its own path-extraction logic before lookup.
  # Use absolute paths (~ is expanded). Longest-prefix match wins.
  project_mappings: {}
    # "/Users/youruser/code/myproject": myproject
    # "/Users/youruser/code/another":   another

  adapters:
    claude_code:
      enabled: true
      watch_paths:
        - "~/.claude/projects"
      file_pattern: "*.jsonl"
      project_detection: path

    openclaw:
      enabled: false
      watch_paths:
        - "~/.openclaw/agents/*/sessions"
      file_pattern: "*.jsonl"
      project_detection: content
      # OpenClaw sessions don't carry path metadata. Set the slug all
      # OpenClaw sessions belong to (or use agent_projects per-agent).
      default_project: null
      agent_projects: {}
        # research_agent: someproject

    codex:
      enabled: false  # Enable when adapter is built
      watch_paths:
        - "~/.codex"
      file_pattern: "*.json"
      project_detection: path

    gemini:
      enabled: false
      watch_paths:
        - "~/.gemini/tmp"
      file_pattern: "session-*.json"
      # Optional: map specific tmp/<dir_name> entries directly.
      dir_to_project: {}
        # myproject: myproject
      # Optional: route by keyword in the dir name (case-insensitive).
      project_keywords: {}
        # myproject:
        #   - api
        #   - frontend

    markdown_memory:
      enabled: false
      # Map of memory directories to project slugs.
      memory_dirs: {}
        # "~/code/myproject/memory": myproject

  codebase_indexer:
    trigger: git_hook  # or "periodic"
    periodic_interval_minutes: 30
    file_types:
      - py
      - ts
      - tsx
      - js
      - sql
    ignore_patterns:
      - node_modules
      - .venv
      - __pycache__
      - dist
      - build
      - .next

factory:
  # Per-project source tree paths. Used by the cleanup agent and other
  # phases that need to operate on a project's local checkout.
  # Falls back to ~/<slug> with a warning if a project is not listed.
  project_paths: {}
    # myproject: "~/code/myproject"

  max_concurrent_jobs: 2
  max_fix_loop_retries: 5
  default_review_passes:
    - architecture
    - security_hipaa
  cli_preferences:
    planning: claude          # Best for reasoning/planning
    implementing: claude      # Code generation (claude, codex, or gemini)
    review_arch: claude       # Architecture review
    review_security: claude   # Security/HIPAA review
    fix: claude               # Fix loop
    # qa: local — QA runs lint/test commands directly, no LLM

  # Per-phase tool-use ceiling passed to `claude -p --max-turns`.
  # Acts as a runaway-protection / wall-clock cap for each phase, NOT
  # a speed limit for normal work. Too low → false failures on legit
  # jobs. Too high → stuck agents burn subscription quota before
  # surfacing. Tune per phase based on the work each actually does:
  #   planning    — reads + DevBrain search + plan write (tight)
  #   implementing — reads + edits + test iterations (needs headroom)
  #   review_*    — read-only audit (tight is fine)
  #   qa          — read-only status check
  #   fix         — between planning and implementing in scope
  # Bumped to 200 uniformly on 2026-04-25 after observing factory jobs
  # legitimately need more headroom for deep_search-driven planning,
  # multi-file refactors, and fix-loop iteration. Wall-clock timeouts in
  # cli_executor still cap runaway agents. Tighten if you want stricter
  # cost controls on a specific phase.
  max_turns:
    planning: 200
    implementing: 200
    review_arch: 200
    review_security: 200
    qa: 200
    fix: 200
  cleanup:
    soft_timer_seconds: 600       # 10 min — triggers self-assessment
    extension_seconds: 300        # 5 min per extension
    hard_ceiling_seconds: 1800    # 30 min — absolute maximum
    auto_archive_after_hours: 24  # Archive completed jobs after 24h in context
    branch_cleanup: true          # Delete branches for failed/rejected jobs

  # Fix-loop trigger tier. When true (default as of 2026-04-23), reviewer
  # WARNING findings also route a job through FIX_LOOP alongside BLOCKING
  # findings. Set false to restore the pre-2026-04-23 BLOCKING-only gate
  # — useful if reviewer calibration leans too cautious on a given project.
  # max_fix_loop_retries still caps total fix attempts either way.
  fix_loop:
    warnings_trigger_retry: true

  # What factory-spawned claude subprocesses are allowed to do.
  #   1 — Read-only audit: file reads, git log/diff/status only. Factory
  #       can observe but not modify anything. Use for dry runs, untrusted
  #       specs, or CI validation.
  #   2 — Guarded dev (recommended): Read/Write/Edit plus a curated
  #       allowlist of dev commands grouped into subcategories you can
  #       toggle (see permissions_tier_2_subcategories below).
  #   3 — Unrestricted: passes --dangerously-skip-permissions to claude.
  #       Full autonomy — filesystem, network, arbitrary shell. Use only
  #       for power-user workflows with trusted specs.
  # The interactive wizard (`devbrain setup mcp`, or
  # `devbrain setup factory-permissions`) lets you pick this without
  # editing yaml.
  permissions_tier: 2

  # Tier 2 subcategory toggles. Each is y/N during `devbrain setup
  # factory-permissions`. Only consulted when permissions_tier == 2.
  #
  # git_push is default OFF so the factory commits locally and the
  # developer reviews the branch before pushing. Flip it to true if
  # you want the factory to push and create PRs on its own.
  permissions_tier_2_subcategories:
    file_modification: true    # Write, Edit
    git_commit: true           # add, commit, branch, checkout, reset, stash, rebase, tag, worktree
    git_push: false            # push, pull, fetch, merge, gh (PR creation)
    python: true               # pytest, python, ruff, black, mypy, uv, pip
    node_typescript: true      # npm, node, tsc, yarn, jest, prettier, eslint, pnpm, npx
    build_tools: true          # make, cargo, go
    filesystem_ops: true       # mkdir, cp, mv, touch
    devbrain_mcp_writes: true  # store, end_session, devbrain_notify

  # Extra --allowedTools entries appended to tier 1/2 (ignored at tier 3).
  # Use Tool(pattern) syntax, e.g. "Bash(terraform:*)".
  permissions_extra_allowed_tools: []

  # Long-running processes that hold cached database credentials.
  # rotate-db-password reloads each one after the rotation lands and
  # verifies it can authenticate; if any verification fails, the
  # rotation rolls back. Add custom entries here for forks/integrations.
  cred_dependents:
    - id: ingest_daemon
      type: launchagent
      label: com.devbrain.ingest
      plist: ~/Library/LaunchAgents/com.devbrain.ingest.plist
      verify: tail_log_no_auth_errors
      verify_log: ~/devbrain/logs/ingest.err.log
      verify_window_seconds: 10
    # Future: factory dashboard, codebase indexer, etc. as they become
    # daemonized. MCP servers spawned by Claude Desktop are intentionally
    # NOT registerable — Claude Desktop owns the lifecycle, so rotation
    # prints a "please restart Claude Desktop" tail message instead.

notifications:
  notify_events:
    - job_started
    - job_ready
    - job_failed
    - blocked              # NEW
    - lock_conflict
    - unblocked
    - needs_human
    - recovery_started
    - recovery_succeeded

  channels:
    tmux:
      enabled: true
      popup_width: 70
      popup_height: 20

    smtp:
      enabled: false
      host: smtp.example.com
      port: 587
      use_tls: true
      username: ""
      password: ""
      sender_email: "devbrain@example.com"
      sender_display_name: "DevBrain"

    gmail_dwd:
      enabled: false
      service_account_path: "~/.devbrain/credentials/gmail-sa.json"
      sender_email: "devbrain@your-workspace.com"
      sender_display_name: "DevBrain"

    gchat_dwd:
      enabled: false
      service_account_path: "~/.devbrain/credentials/gchat-sa.json"
      sender_email: "devbrain@your-workspace.com"
      auto_create_dm_space: true

    telegram_bot:
      enabled: false
      bot_token: ""
      bot_username: ""

    webhook_slack:
      enabled: false

    webhook_discord:
      enabled: false

    webhook_generic:
      enabled: false
