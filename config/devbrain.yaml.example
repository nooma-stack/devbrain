# DevBrain Configuration (Template)
# ==================================
# Copy this file to config/devbrain.yaml and fill in your values.
# The real config/devbrain.yaml is gitignored so secrets stay local.

database:
  host: localhost
  port: 5433
  user: devbrain
  password: devbrain-local
  database: devbrain

embedding:
  provider: ollama
  url: http://localhost:11434
  model: snowflake-arctic-embed2
  dims: 1024

summarization:
  provider: ollama
  url: http://localhost:11434
  model: qwen2.5:7b

chunking:
  max_tokens: 400
  overlap_tokens: 80

ingest:
  adapters:
    claude_code:
      enabled: true
      watch_paths:
        - "~/.claude/projects"
      file_pattern: "*.jsonl"
      project_detection: path

    openclaw:
      enabled: true
      watch_paths:
        - "~/.openclaw/agents/*/sessions"
      file_pattern: "*.jsonl"
      project_detection: content

    codex:
      enabled: false  # Enable when adapter is built
      watch_paths:
        - "~/.codex"
      file_pattern: "*.json"
      project_detection: path

  codebase_indexer:
    trigger: git_hook  # or "periodic"
    periodic_interval_minutes: 30
    file_types:
      - py
      - ts
      - tsx
      - js
      - sql
    ignore_patterns:
      - node_modules
      - .venv
      - __pycache__
      - dist
      - build
      - .next

factory:
  max_concurrent_jobs: 2
  max_fix_loop_retries: 5
  default_review_passes:
    - architecture
    - security_hipaa
  cli_preferences:
    planning: claude          # Best for reasoning/planning
    implementing: claude      # Code generation (claude, codex, or gemini)
    review_arch: claude       # Architecture review
    review_security: claude   # Security/HIPAA review
    fix: claude               # Fix loop
    # qa: local — QA runs lint/test commands directly, no LLM
  cleanup:
    soft_timer_seconds: 600       # 10 min — triggers self-assessment
    extension_seconds: 300        # 5 min per extension
    hard_ceiling_seconds: 1800    # 30 min — absolute maximum
    auto_archive_after_hours: 24  # Archive completed jobs after 24h in context
    branch_cleanup: true          # Delete branches for failed/rejected jobs

notifications:
  notify_events:
    - job_ready
    - job_failed
    - lock_conflict
    - unblocked
    - needs_human

  channels:
    tmux:
      enabled: true
      popup_width: 70
      popup_height: 20

    smtp:
      enabled: false
      host: smtp.example.com
      port: 587
      use_tls: true
      username: ""
      password: ""
      sender_email: "devbrain@example.com"
      sender_display_name: "DevBrain"

    gmail_dwd:
      enabled: false
      service_account_path: "~/.devbrain/credentials/gmail-sa.json"
      sender_email: "devbrain@your-workspace.com"
      sender_display_name: "DevBrain"

    gchat_dwd:
      enabled: false
      service_account_path: "~/.devbrain/credentials/gchat-sa.json"
      sender_email: "devbrain@your-workspace.com"
      auto_create_dm_space: true

    telegram_bot:
      enabled: false
      bot_token: ""
      bot_username: ""

    webhook_slack:
      enabled: false

    webhook_discord:
      enabled: false

    webhook_generic:
      enabled: false
