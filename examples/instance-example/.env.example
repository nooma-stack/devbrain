# Example instance environment.
#
# Copy to `.env` in your instance repo root. The .env file is gitignored.
# See devbrain/.env.example for the full DevBrain env var contract.

# ─── Point DevBrain at this instance's config ────────────────────────────────
# Until the instance-aware loader lands (Phase 1), tell DevBrain's config
# loader to read this instance's instance.yaml instead of the engine default.
DEVBRAIN_CONFIG=./instance.yaml

# ─── Postgres ────────────────────────────────────────────────────────────────
# Uncomment and set if your instance uses a different DB than the engine default.
# DEVBRAIN_DATABASE_URL=postgresql://devbrain:devbrain-local@localhost:5433/devbrain

# ─── Notification secrets (only fill in what you enabled in instance.yaml) ───
# DEVBRAIN_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# DEVBRAIN_SMTP_PASSWORD=
# TELEGRAM_BOT_TOKEN=
